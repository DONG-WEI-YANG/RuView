# WiFi Body — Environment Configuration
# Copy this file to .env and adjust values for your deployment.
# All fields have sensible defaults; only override what you need.

# ── Network ─────────────────────────────────────────────
udp_host=0.0.0.0
udp_port=5005
api_host=0.0.0.0
api_port=8000

# ── Hardware Profile ────────────────────────────────────
# Options: esp32s3, esp32s3_mmfi, tplink_n750, intel5300, esp32c6_wifi6
hardware_profile=esp32s3

# ── CSI Parameters (overridden by hardware profile) ────
num_subcarriers=56
csi_sample_rate=20
max_nodes=6

# ── Model ───────────────────────────────────────────────
num_joints=24
model_path=models/esp32s3/pose_model.pth

# ── Scene Mode ──────────────────────────────────────────
# "safety" = elderly fall detection (sensitive)
# "fitness" = exercise tracking (strict, fewer false alarms)
scene_mode=safety

# ── Fall Detection ──────────────────────────────────────
fall_threshold=0.8
fall_alert_cooldown=30

# ── Room Geometry (meters, origin = floor center) ──────
room_width=4.0
room_depth=4.0
room_height=2.8

# ── Node Positions (JSON: {node_id: [x, y, z]}) ───────
# node_positions={"1": [2.0, 1.5, 2.0], "2": [2.0, 1.0, -2.0], "3": [-2.0, 0.5, -2.0], "4": [-2.0, 1.0, 2.0]}

# ── Storage ─────────────────────────────────────────────
db_path=data/wifi_body.db

# ── Simulation ──────────────────────────────────────────
simulate=false

# ── Push Notifications (leave blank to disable) ────────
notify_webhook_url=
notify_line_token=
notify_telegram_bot_token=
notify_telegram_chat_id=

# ── Firmware Build Paths (override for your machine) ───
# CSI_BUILD_DIR=C:/temp/csi-node
# CSI_PIO_EXE=C:/temp/pio-env/Scripts/pio.exe
